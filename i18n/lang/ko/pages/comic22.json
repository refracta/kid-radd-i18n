  "strings": {
    "title.main.html": "\"변화, 변화\"",
    "panel.p1.bubble.center.html": "임무 완료!",
    "panel.p2.bubble.center.html": "그래서, \"여자친구\"님? 우리 둘이서 한번?...",
    "panel.p3.bubble.center.html": "야, 멋진 놈은 원래 좀 나쁜 법이지.",
    "panel.p4.bubble.center.html": "웩!",
    "panel.p1.bubble.left.html": "아야...",
    "panel.p1.bubble.right.html": "그렇지.",
    "panel.p2.bubble.left.html": "내 콩팥이...",
    "panel.p2.bubble.right.html": "음, 그 전투 너무 쉬웠던 거 아니야?",
    "panel.p3.bubble.left.html": "변신... 해야 해...",
    "panel.p3.bubble.right.html": "내 말은, 어쩌면 저게 보스의...",
    "panel.p4.bubble.left.html": "자, 그날리 나가신다!",
    "panel.p4.bubble.right.html": "...최종 형태."
  }
}
