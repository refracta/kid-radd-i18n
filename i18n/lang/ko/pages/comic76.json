  "strings": {
    "title.main.html": "\"너무 신나\"",
    "panel.p1.bubble.left.html": "얘들아! 맞춰봐!",
    "panel.p1.bubble.center.html": "오늘도 용사님 텐션 높네.",
    "panel.p1.bubble.right.html": "매일 그렇지 뭐.",
    "panel.p2.bubble.left.html": "나 취직했어! 완전 좋은 일!",
    "panel.p2.bubble.right.html": "무슨 일인데?",
    "panel.p3.bubble.left.html": "이제 난 \"채팅방 아바타\"야!",
    "panel.p3.bubble.center.html": "뭐라고?",
    "panel.p3.bubble.right.html": "그게 뭔데?",
    "panel.p4.bubble.left.html": "나도 몰라. 근데 <i>인간</i>이랑 일할 수 있대! 우릴 가지고 놀던 그 창조자들 말이야! 완전 끝내줄 거야! 나중에 봐!",
    "panel.p5.bubble.center.html": "얘 스스로 실망할 준비하는 거지?",
    "panel.p5.bubble.right.html": "엄청나게.",
    "panel.p1.extra.1.html": "얘들아! 맞춰봐!",
    "panel.p1.extra.2.html": "오늘도 용사님 텐션 높네.",
    "panel.p1.extra.3.html": "매일 그렇지 뭐.",
    "panel.p2.extra.1.html": "나 취직했어! 완전 좋은 일!",
    "panel.p2.extra.2.html": "무슨 일인데?",
    "panel.p3.extra.1.html": "이제 난 \"채팅방 아바타\"야!",
    "panel.p3.extra.2.html": "뭐라고?",
    "panel.p3.extra.3.html": "그게 뭔데?",
    "panel.p4.extra.1.html": "나도 몰라. 근데 <i>인간</i>이랑 일할 수 있대! 우릴 가지고 놀던 그 창조자들 말이야! 완전 끝내줄 거야! 나중에 봐!",
    "panel.p5.extra.1.html": "얘 스스로 실망할 준비하는 거지?",
    "panel.p5.extra.2.html": "엄청나게."
  }
