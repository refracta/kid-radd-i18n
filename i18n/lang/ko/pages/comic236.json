  "strings": {
    "title.main.html": "\"최후의 시간\"",
    "panel.p1.bubble.center.html": "끝이야. 무적이 풀리는 순간 난 죽어.",
    "panel.p2.bubble.center.html": "미안해, 모두. 나도 해보긴 했어...",
    "panel.p3.narration.1.html": "그런데 이상하게도...",
    "panel.p3.bubble.center.html": "잠깐. 사격이... 멈췄어?",
    "panel.p4.bubble.left.html": "시나?",
    "panel.p4.bubble.center.html": "멈춰! 난 래드를 다치게 안 둘 거야!",
    "panel.p4.bubble.right.html": "아, 진짜 별걸 다 보겠네.",
    "panel.p5.bubble.left.html": "고, 고마워...",
    "panel.p5.bubble.right.html": "축하해. 네가 걔 수명을 3초 늘려줬다.",
    "panel.p1.extra.1.html": "끝이야. 무적이 풀리는 순간 난 죽어.",
    "panel.p2.extra.1.html": "미안해, 모두. 나도 해보긴 했어...",
    "panel.p3.extra.1.html": "그런데 이상하게도...",
